NODE_ENV=production
NEXT_PUBLIC_APP_NAME="Nusa Escape Smart Glamping OS"

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=smart_glamping
DATABASE_URL="postgresql://postgres:change-this-postgres-password@postgres:5432/smart_glamping?schema=public"

AUTH_SECRET="replace-with-at-least-32-random-bytes"

HTTP_PORT=80

OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_PRIMARY_MODEL=openrouter/auto
OPENROUTER_FALLBACK_MODELS=~anthropic/claude-sonnet-latest
